# ─────────────────────────────────────────────────────────────────────────────
# KawKaw Catalog — environment variables
#
# FOR PORTAINER: Do NOT use this file. Set variables in Portainer's
# "Environment variables" editor when deploying the stack.
#
# FOR LOCAL CLI USAGE: copy to .env and fill in the required values.
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# PostgreSQL
POSTGRES_USER=kawkaw
POSTGRES_PASSWORD=changeme         # REQUIRED — use a strong password
POSTGRES_DB=kawkaw
DATABASE_URL=postgresql+asyncpg://kawkaw:changeme@postgres:5432/kawkaw

# Redis
REDIS_URL=redis://redis:6379/0

# JWT  — generate with: openssl rand -hex 32
JWT_SECRET_KEY=change-me-generate-with-openssl-rand-hex-32   # REQUIRED
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# Host path where the TrueNAS SMB share is mounted (Docker host, not container)
MEDIA_HOST_PATH=/mnt/truenas_photos

# Media paths inside containers — do not change unless you edit docker-compose.yml
MEDIA_ROOT=/mnt/media
THUMBS_ROOT=/mnt/thumbs

# Public URL of the API — set to http://YOUR_HOST_IP/api   REQUIRED
NEXT_PUBLIC_API_URL=http://localhost/api
