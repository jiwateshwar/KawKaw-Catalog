# PostgreSQL
POSTGRES_USER=kawkaw
POSTGRES_PASSWORD=changeme
POSTGRES_DB=kawkaw
DATABASE_URL=postgresql+asyncpg://kawkaw:changeme@postgres:5432/kawkaw

# Redis
REDIS_URL=redis://redis:6379/0

# JWT  (generate with: openssl rand -hex 32)
JWT_SECRET_KEY=change-me-generate-with-openssl-rand-hex-32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# TrueNAS SMB Share
# Mount the share on the Docker host via /etc/fstab, then set MEDIA_ROOT to the mount point.
# Example fstab entry:
#   //192.168.1.x/photos /mnt/truenas_photos cifs credentials=/etc/samba/kawkaw.creds,uid=1000,gid=1000,file_mode=0444,dir_mode=0555,vers=3.0,_netdev 0 0
SMB_HOST=192.168.1.x
SMB_SHARE=photos
SMB_USER=kawkaw_reader
SMB_PASS=smb_password

# Media paths (inside containers)
MEDIA_ROOT=/mnt/media
THUMBS_ROOT=/mnt/thumbs

# Seed admin user (created on first startup if no users exist)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme_on_first_login

# Next.js public env vars (must start with NEXT_PUBLIC_)
NEXT_PUBLIC_API_URL=http://localhost/api
